<Project>
  <PropertyGroup Condition="'$(OS)' == 'Windows_NT'">
    <OuterWildsModsDirectory>$(AppData)/OuterWildsModManager/OWML/Mods</OuterWildsModsDirectory>
  </PropertyGroup>
  <PropertyGroup Condition="'$(OS)' == 'Unix'">
    <OuterWildsModsDirectory>$(HOME)/.local/share/OuterWildsModManager/OWML/Mods</OuterWildsModsDirectory>
  </PropertyGroup>
  <PropertyGroup>
    <OutputPath>$(OuterWildsModsDirectory)/AnonymousStrangerOW.TheStrangerTheyAre/</OutputPath>
    <UnityPath>D:/tsta-unity/</UnityPath>
    <UnityDllsDir>$(UnityPath)Assets/</UnityDllsDir>
    <UnityBundlesDir>$(UnityPath)AssetBundles/StandaloneWindows/</UnityBundlesDir>
  </PropertyGroup>
</Project>